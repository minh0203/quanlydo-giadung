  <property name="styleSheet">
   <string notr="true">
    QWidget {
        background-color: #f0f2f5;
    }
    QGroupBox {
        font-weight: bold;
        border: 2px solid #e1e8ed;
        border-radius: 12px;
        margin-top: 12px;
        padding-top: 12px;
        background-color: white;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 15px;
        padding: 0 8px 0 8px;
        color: #2c3e50;
        font-size: 16px;
    }
    QTableWidget {
        background-color: white;
        alternate-background-color: #f9f9f9;
        gridline-color: #e0e0e0;
        selection-background-color: #3498db;
        selection-color: white;
        border-radius: 10px;
        font-size: 14px;
    }
    QHeaderView::section {
        background-color: #3498db;
        color: white;
        padding: 12px;
        font-weight: bold;
        font-size: 14px;
        border: none;
    }
    QPushButton {
        border-radius: 8px;
        padding: 10px 24px;
        font-weight: bold;
        font-size: 16px;
        min-width: 120px;
        min-height: 40px;
    }
    QPushButton#btnSearch {
        background-color: #3498db;
        color: white;
    }
    QPushButton#btnSearch:hover {
        background-color: #2980b9;
    }
    QPushButton#btnExport {
        background-color: #27ae60;
        color: white;
    }
    QPushButton#btnExport:hover {
        background-color: #2ecc71;
    }
    QPushButton#btnPrint {
        background-color: #9b59b6;
        color: white;
    }
    QPushButton#btnPrint:hover {
        background-color: #8e44ad;
    }
    QPushButton#btnReset {
        background-color: #e67e22;
        color: white;
    }
    QLineEdit, QComboBox {
        padding: 12px 16px;
        border: 1px solid #dcdfe6;
        border-radius: 8px;
        background-color: white;
        font-size: 16px;
        min-height: 35px;
    }
    QLabel {
        color: #2c3e50;
        font-size: 14px;
        font-weight: bold;
    }
    QLabel#lblTitle {
        font-size: 26px;
        font-weight: bold;
        color: #2c3e50;
    }
    QLabel#lblTotalValue {
        font-size: 28px;
        font-weight: bold;
        color: #27ae60;
    }
    QProgressBar {
        border-radius: 6px;
        text-align: center;
        font-weight: bold;
        height: 25px;
    }
    QProgressBar::chunk {
        border-radius: 6px;
        background-color: #3498db;
    }
   </string>
