    }
    QPushButton#btnPrint {
        background-color: #1abc9c;
        color: white;
    }
    QLineEdit, QComboBox, QDateEdit, QTextEdit {
        padding: 12px 16px;
        border: 1px solid #dcdfe6;
        border-radius: 8px;
        background-color: white;
        font-size: 16px;
