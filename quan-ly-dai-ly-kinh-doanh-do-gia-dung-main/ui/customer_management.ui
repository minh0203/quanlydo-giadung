        background-color: #f39c12;
        color: white;
    }
    QPushButton#btnSearch {
        background-color: #9b59b6;
        color: white;
    }
    QLineEdit, QComboBox, QTextEdit {
        padding: 8px 12px;
        border: 1px solid #dcdfe6;
        border-radius: 8px;
        background-color: white;
        font-size: 13px;
    }
    QLineEdit:focus, QComboBox:focus {
        border-color: #9b59b6;
        outline: none;
    }
    QLabel {
        color: #2c3e50;
    }
    QLabel#lblTitle {
