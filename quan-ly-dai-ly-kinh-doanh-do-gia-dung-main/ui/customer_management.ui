        border: none;
    }
    QPushButton {
        border-radius: 8px;
        padding: 8px 18px;
        font-weight: bold;
        font-size: 13px;
    }
    QPushButton#btnAdd {
        background-color: #27ae60;
        color: white;
    }
    QPushButton#btnAdd:hover {
        background-color: #2ecc71;
    }
    QPushButton#btnEdit {
