  <property name="windowTitle">
   <string>Phần mềm quản lý kinh doanh đồ gia dụng</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #f0f2f5;
    }
    
    /* ===== MENU BAR ===== */
    QMenuBar {
        background-color: #2c3e50;
        color: white;
        padding: 12px 8px;
        font-size: 18px;
        font-weight: bold;
        min-height: 50px;
    }
    
    QMenuBar::item {
        padding: 10px 22px;
        margin: 0 5px;
        border-radius: 6px;
        font-size: 17px;
    }
    
    QMenuBar::item:selected {
        background-color: #3498db;
    }
    
    QMenuBar::item:pressed {
        background-color: #2980b9;
    }
    
    /* ===== MENU DROP DOWN - CHỮ TO HƠN ===== */
    QMenu {
        background-color: white;
        color: #2c3e50;
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 10px;
        font-size: 16px;
    }
    
    QMenu::item {
        padding: 12px 50px;
        margin: 4px 8px;
        border-radius: 6px;
        font-size: 16px;
    }
    
    QMenu::item:selected {
        background-color: #3498db;
        color: white;
    }
    
    QMenu::separator {
        height: 2px;
        background-color: #ddd;
        margin: 8px 12px;
    }
    
    /* ===== STATUS BAR ===== */
    QStatusBar {
        background-color: #34495e;
        color: white;
        font-size: 13px;
        padding: 8px;
    }
    
    QStatusBar::item {
        border: none;
    }
   </string>
  </property>
  
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">
