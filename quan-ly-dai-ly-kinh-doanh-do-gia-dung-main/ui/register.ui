  <property name="styleSheet">
   <string notr="true">
    QDialog {
        background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
            stop:0 #667eea, stop:1 #764ba2);
    }
    QFrame#frameRegister {
        background-color: white;
        border-radius: 20px;
        padding: 30px;
    }
    QLabel#lblTitle {
        font-size: 28px;
        font-weight: bold;
        color: #2c3e50;
    }
    QLabel#lblSubtitle {
        font-size: 14px;
        color: #7f8c8d;
        margin-bottom: 20px;
    }
    QLabel {
        color: #2c3e50;
        font-weight: bold;
    }
    QLineEdit {
        padding: 12px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 14px;
        background-color: #f8f9fa;
    }
    QLineEdit:focus {
        border-color: #667eea;
        background-color: white;
    }
    QComboBox {
        padding: 10px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 14px;
        background-color: #f8f9fa;
    }
    QComboBox:focus {
        border-color: #667eea;
    }
    QPushButton {
        border-radius: 10px;
        padding: 12px;
        font-size: 16px;
        font-weight: bold;
    }
    QPushButton#btnRegister {
        background-color: #27ae60;
        color: white;
    }
    QPushButton#btnRegister:hover {
        background-color: #2ecc71;
    }
    QPushButton#btnCancel {
        background-color: #95a5a6;
        color: white;
    }
    QPushButton#btnCancel:hover {
        background-color: #7f8c8d;
    }
    QPushButton#btnLogin {
        background-color: #3498db;
        color: white;
    }
    QPushButton#btnLogin:hover {
        background-color: #2980b9;
    }
    QCheckBox {
        color: #555;
    }
    QLabel#lblError {
        color: #e74c3c;
        font-size: 12px;
    }
    QLabel#lblSuccess {
        color: #27ae60;
        font-size: 12px;
    }
   </string>
